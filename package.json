{
  "name": "MQTTBox",
  "version": "0.2.2",
  "description": "MQTTBox - Developers helper program to create and test MQTT connectivity protocol.",
  "author": {
    "name": "WorksWithWeb",
    "email": "workswithweb@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:workswithweb/MQTTBox.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "gulp",
    "build": "gulp build",
    "electron": "electron .",
    "electron-dev": "NODE_ENV=development electron .",
    "dist": "npm run build && electron-builder",
    "dist-mac": "npm run build && electron-builder --mac",
    "dist-win": "npm run build && electron-builder --win",
    "dist-linux": "npm run build && electron-builder --linux",
    "dist-all": "npm run build && electron-builder --mac --win --linux",
    "pack": "npm run build && electron-builder --dir"
  },
  "private": true,
  "devDependencies": {
    "babel-cli": "^6.18.0",
    "babel-core": "6.20.0",
    "babel-preset-es2015": "6.18.0",
    "babel-preset-react": "6.16.0",
    "babelify": "7.3.0",
    "browser-sync": "2.18.2",
    "browserify": "13.1.1",
    "electron": "^22.0.0",
    "electron-builder": "^24.6.4",
    "gulp": "^4.0.2",
    "gulp-notify": "2.2.0",
    "gulp-util": "3.0.7",
    "pretty-hrtime": "1.0.3",
    "require-dir": "0.3.1",
    "underscore": "1.8.3",
    "vinyl-buffer": "^1.0.1",
    "vinyl-source-stream": "1.1.0",
    "watchify": "3.7.0"
  },
  "dependencies": {
    "compare-versions": "3.0.0",
    "fixed-data-table": "0.6.3",
    "flux": "3.1.0",
    "getmac": "1.2.1",
    "localforage": "1.4.3",
    "lodash": "4.17.2",
    "moment": "2.17.1",
    "mqtt": "^4.3.8",
    "node-uuid": "1.4.7",
    "q": "1.4.1",
    "qlobber": "0.7.0",
    "react": "15.4.1",
    "react-copy-to-clipboard": "4.2.3",
    "react-dom": "15.4.1",
    "react-router": "3.0.0",
    "recharts": "0.19.0",
    "request": "2.79.0"
  },
  "build": {
    "appId": "com.workswithweb.mqttbox",
    "productName": "MQTTBox",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "main.js",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/images/icon-512.png",
      "darkModeSupport": true
    },
    "dmg": {
      "title": "MQTTBox",
      "icon": "build/images/icon-512.png",
      "background": null,
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/images/icon-512.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/images/icon-512.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
